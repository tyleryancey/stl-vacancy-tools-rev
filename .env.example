# Backend data provider: "mock" (default, runs out-of-the-box with sample data)
# or "firebase" (wire to a real Firebase project).
VITE_DATA_PROVIDER=mock

# Base map style (free, no token). OpenFreeMap positron by default.
VITE_MAP_STYLE=https://tiles.openfreemap.org/styles/positron

# --- Firebase provider (only needed when VITE_DATA_PROVIDER=firebase) ---
# A Firebase *web* apiKey is a public app identifier, not a secret (see REVERSE-ENGINEERING.md §11).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Live St. Louis city parcel-data aggregator used by the scoring engine.
# Leave as-is to use the real upstream; the app degrades gracefully if unreachable.
VITE_CITY_DATA_BASE=https://vcpp.stldata.org/parcel_data/
